# Database
DATABASE_URL=postgresql://user:password@localhost:5432/faculty_reports

# App URL
NEXTAUTH_URL=http://localhost:3000

# S3 Cloud Storage (for photo uploads)
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=faculty-reports
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1

# AI Integration (Optional - for Gemma / any OpenAI-compatible endpoint)
# Uncomment and configure when you have a Gemma server running
# AI_ENDPOINT=http://localhost:11434/v1
# AI_MODEL=gemma2:2b
# AI_API_KEY=
